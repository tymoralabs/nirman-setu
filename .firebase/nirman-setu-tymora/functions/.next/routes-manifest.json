  "dynamicRoutes": [
    {
      "page": "/accept-invite/[token]",
      "regex": "^/accept\\-invite/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/accept\\-invite/(?<nxtPtoken>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
